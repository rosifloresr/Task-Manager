{
  "name": "minimal-ecommerce-backend",
  "version": "0.0.1",
  "description": "Minimalist E-commerce Core",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:auth": "nest start auth-service --watch",
    "start:products": "nest start products-service --watch",
    "start:gateway": "nest start api-gateway --watch",
    "dev": "concurrently \"npm run start:auth\" \"npm run start:products\" \"npm run start:gateway\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "seed:auth": "dotenv -e apps/auth-service/.env -- ts-node apps/auth-service/src/prisma/seed.ts",
    "seed:prod": "dotenv -e apps/products-service/.env -- ts-node apps/products-service/src/prisma/seed.ts",
    "prisma:auth:mig": "dotenv -e apps/auth-service/.env -- npx prisma migrate dev --schema=apps/auth-service/src/prisma/schema.prisma",
    "prisma:prod:mig": "dotenv -e apps/products-service/.env -- npx prisma migrate dev --schema=apps/products-service/src/prisma/schema.prisma",
    "prisma:auth:gen": "dotenv -e apps/auth-service/.env -- npx prisma generate --schema=apps/auth-service/src/prisma/schema.prisma",
    "prisma:prod:gen": "dotenv -e apps/products-service/.env -- npx prisma generate --schema=apps/products-service/src/prisma/schema.prisma",
    "prisma:orders:gen": "dotenv -e apps/orders-service/.env -- npx prisma generate --schema=apps/orders-service/src/prisma/schema.prisma",
    "prisma:orders:mig": "dotenv -e apps/orders-service/.env -- npx prisma migrate dev --schema=apps/orders-service/src/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.18",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.19.2",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "http-proxy-middleware": "^3.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}